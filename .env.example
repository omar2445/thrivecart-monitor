# ThriveCart webhook secret (set this in your ThriveCart dashboard under Webhooks)
THRIVECART_SECRET=your_thrivecart_webhook_secret_here

# SMTP settings (works with Gmail, Outlook, or any SMTP provider)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
SMTP_FROM=your_email@gmail.com

# Who receives the overdue notifications (your client's email)
NOTIFY_EMAIL=client@example.com
NOTIFY_NAME=Your Client Name

# How many hours after missed payment to send the alert (default: 24)
OVERDUE_HOURS=24

# Database (SQLite by default, no setup needed)
DATABASE_URL=sqlite:///./thrivecart.db

# Server
PORT=8000
